@model Model.Cooperative.OfflineMember

@{
    ViewData["Title"] = "Edit";
}
<link href="~/css/livestockeditdetails.css" rel="stylesheet" />
<style>
    /* Custom CSS styles for the offline member details section */
    .thumbnail-gallery {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-bottom: 20px;
    }

    .thumbnail-image {
        width: 100px;
        height: 100px;
        object-fit: cover;
        border-radius: 5px;
        cursor: pointer;
    }

    .main-image-container {
        position: relative;
        width: 300px;
        height: 300px;
        border: 2px solid #ddd;
        border-radius: 5px;
        overflow: hidden;
    }

    .main-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .main-image-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .main-image-container:hover .main-image-overlay {
        opacity: 1;
    }

    .main-image-overlay-text {
        color: #fff;
        font-size: 24px;
        font-weight: bold;
        text-align: center;
    }

    .form-group {
        margin-bottom: 30px;
    }

    label {
        display: block;
        font-size: 18px;
        font-weight: bold;
        margin-bottom: 10px;
    }

</style>


 <h4>@Model.MembreId</h4>

<hr />

<article class="container cooperative-details">
    <form method="post" action="@Url.Action("Edit", "OfflineMember", new { id = Model.Person.PersonId })" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <div class="row">
            <div class="col-md-6">
               
                    <div class="card-body">
                        <h2>Edit Details</h2>
                        <div class="form-group">
                            <label asp-for="@Model.Person.FirstName">First Name:</label>
                            <input asp-for="@Model.Person.FirstName" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label asp-for="@Model.Person.LastName">Last Name:</label>
                            <input asp-for="@Model.Person.LastName" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label asp-for="@Model.Person.IdNumber">ID Number:</label>
                            <input asp-for="@Model.Person.IdNumber" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label asp-for="@Model.Person.City">City:</label>
                            <input asp-for="@Model.Person.City" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label asp-for="@Model.Person.Country">Country:</label>
                            <input asp-for="@Model.Person.Country" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label asp-for="@Model.Person.PhoneNumber">PhoneNumber:</label>
                            <input asp-for="@Model.Person.PhoneNumber" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label asp-for="@Model.FeesPerYear">Last Name:</label>
                            <input asp-for="@Model.FeesPerYear" class="form-control" />
                        </div>
                    </div>
                
            </div>
            
            <div class="col-md-6">
                <div class="card">
                    <div class="card-body">
                        <div class="form-group">
                            <label asp-for="@Model.Person.PersonImageUrl">Person Image:</label>
                            <div class="image-fluid">
                                @if (!string.IsNullOrEmpty(@Model.Person.PersonImageUrl))
                                {
                                    <img src="@Model.Person.PersonImageUrl" class="card-img-top img-fluid" alt="person picture" style="height: 200px; width: 100%;">
                                }
                                else
                                {
                                    <img src="https://via.placeholder.com/200x200.png?text=No+Image" class="card-img-top img-fluid" alt="No image" style="height: 200px; width: 100%;">
                                }
                            </div>
                            <input asp-for="@Model.Person.PersonImageUrl" class="form-control mt-2" />

                        </div>
                        <!-- Existing Images Section -->
                        @if (Model.Images != null && Model.Images.Count > 0)
                        {
                            <div class="form-group">
                                <label>Existing Images</label>
                                <div class="thumbnail-gallery">
                                    @foreach (var image in Model.Images)
                                    {
                                        var base64String = Convert.ToBase64String(image.Data);
                                        var imageSource = $"data:image/jpeg;base64,{base64String}";
                                        <img class="thumbnail-image" src="@imageSource" onclick="changeMainImage(this)" />
                                    }
                                </div>
                            </div>
                        }

                        <!-- Main Image Section -->
                        <div class="form-group">
                            <label>Main Image</label>
                            <div class="main-image-container">
                                @if (Model.Images != null && Model.Images.Count > 0)
                                {
                                    var base64String = Convert.ToBase64String(Model.Images.FirstOrDefault().Data);
                                    var mainImageSource = $"data:image/jpeg;base64,{base64String}";
                                    <img id="mainImage" class="main-image" src="@mainImageSource" />
                                }
                                else
                                {
                                    <img id="mainImage" class="main-image" src="#" alt="No Image" />
                                }
                                <div class="main-image-overlay">
                                    <span class="main-image-overlay-text"></span>
                                </div>
                            </div>
                        </div>

                    <div class="card-footer">
                        <button type="submit" class="btn btn-primary btn-lg">Save Changes</button>
                        <a href="#" class="btn btn-secondary btn-lg" data-dismiss="modal">Cancel</a>
                    </div>
                </div>
                
                    <div class="form-group">
                        @Html.Label(" PersonImages")
                        <input type="file" name="imageFiles" multiple accept="image/*" class="form-control-file">
                    </div>
                </div>
        </div>
        </div>
    </form>
</article>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        var thumbnailImages = document.getElementsByClassName("thumbnail-image");
        var mainImage = document.getElementById("mainImage");
        var currentIndex = 0;

        function changeMainImage(element) {
            mainImage.src = element.src;
            for (var i = 0; i < thumbnailImages.length; i++) {
                thumbnailImages[i].classList.remove("active");
            }
            element.classList.add("active");
            currentIndex = Array.from(thumbnailImages).indexOf(element);
        }

        function navigateGallery(direction) {
            currentIndex = (currentIndex + direction + thumbnailImages.length) % thumbnailImages.length;
            changeMainImage(thumbnailImages[currentIndex]);
        }

        for (var i = 0; i < thumbnailImages.length; i++) {
            thumbnailImages[i].addEventListener("click", function () {
                changeMainImage(this);
            });
        }

        document.addEventListener("keydown", function (event) {
            if (event.key === "ArrowLeft") {
                navigateGallery(-1);
            } else if (event.key === "ArrowRight") {
                navigateGallery(1);
            }
        });

    </script>
}

