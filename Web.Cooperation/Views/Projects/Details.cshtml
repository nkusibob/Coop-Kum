@section scripts {

    <script>
        $(document).ready(function () {
            // Hide the "more" text by default
            $(".card-text-more").hide();

            // Show more text when the "Show More" button is clicked
            $(".show-more").on("click", function () {
                $(this).parents(".card-text-wrapper").find(".card-text-more").slideToggle();
                $(this).find("p").text(function (i, text) {
                    return text === "Show More" ? "Show Less" : "Show More";
                });
            });
        });

        
        //function toggleDarkMode() {
        //    // Get the body and card elements
        //    var body = document.getElementsByTagName("body")[0];
        //    var card = document.getElementsByClassName("card")[0];
        //    var cardEmployee = document.getElementsByClassName("card-employee")[0];
        //    var cardBody = document.getElementsByClassName("card-body")[0];
        //    var cardText = document.getElementsByClassName("card-text-wrapper")[0];

        //    // Toggle the dark-mode class on both the body and card elements
        //    body.classList.toggle("dark-mode");
        //    card.classList.toggle("dark-mode");
        //    cardEmployee.classList.toggle("dark-mode");
        //    cardBody.classList.toggle("dark-mode");
        //    cardText.classList.toggle("dark-mode");
        //}
        $(function () {
            $('#simulationForm').submit(function (event) {
                event.preventDefault(); // Prevent the form from being submitted

                var formData = $(this).serialize(); // Serialize the form data

                // Submit the form data using AJAX
                $.ajax({
                    type: 'POST',
                    url: '@Url.Action("GetSimulation")',
                    data: formData,
                    success: function (result) {
                        // Handle the response

                        console.log(result);
                        $("#simulationPeriod").text(result.sentence);
                    },
                    error: function (xhr, status, error) {
                        // Handle errors
                        console.log(xhr.responseText);
                    }
                });
            });
        });
        $(function () {
            $('#employee-search').keyup(function () {
                var searchValue = $(this).val().toLowerCase();
                $('.employee-card').each(function () {
                    var employeeName = $(this).find('.employee-name').text().toLowerCase();
                    if (employeeName.indexOf(searchValue) !== -1) {
                        $(this).show();
                    } else {
                        $(this).hide();
                    }
                });
            });
        });
        $('#stepProject-details-modal').on('hidden.bs.modal', function (e) {
            location.reload();
        });
        $(function () {
            $('.stepProject-btn').on('click', function (event) {
                event.preventDefault(); // prevent default behavior of the link
                var url = $(this).attr('href');
                $.get(url, function (data) {
                    $('#stepProject-details').html(data); // display the project details in the div
                    $('#stepProject-details-modal').modal('show'); // display the modal
                });
            });
        });
        $(function () {
            $('.stepProject-add-btn').on('click', function (event) {
                event.preventDefault(); // prevent default behavior of the link
                var url = $(this).attr('href');
                $.get(url, function (data) {
                    $('#stepProject-add').html(data); // display the project details in the div
                    $('#stepProject-add-modal').modal('show'); // display the modal
                });
            });
        });

     
        

    </script>
}

