@model Model.Cooperative.Project

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Project</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Efficiency" class="control-label"></label>
                <input asp-for="Efficiency" class="form-control" />
                <span asp-validation-for="Efficiency" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="DurationInMonth" class="control-label"></label>
                <input asp-for="DurationInMonth" class="form-control" />
                <span asp-validation-for="DurationInMonth" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ProjectBudget" class="control-label"></label>
                <input asp-for="ProjectBudget" class="form-control" />
                <span asp-validation-for="ProjectBudget" class="text-danger"></span>
            </div>
            <input type="hidden" name="id" value="@ViewBag.IdCoop" />

            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a href="##" onClick="history.go(-1); return false;">Back to List</a>
@*  *@</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
