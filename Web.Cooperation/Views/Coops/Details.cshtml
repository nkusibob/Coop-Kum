                                    </li>
                                </ul>
                                <p>Financial Overview for Projects:</p>
                                <ul>
                                    <li>Total Employee Salaries: @ViewBag.TotalEmployeeSalaries€</li>
                                    <li>Manager Salary: @ViewBag.ManagerSalary€</li>
                                    <li>
                                        <a href="#" class="btn btn-outline-dark" style="background-color: #a9a9a9" data-toggle="modal" data-target="#detailedBudgetModal">Total Projects Expenses: @ViewBag.TotalProjectExpenses€</a>
                                    </li>

                                </ul>



                                <div class="modal fade" id="allEmployeesModal" tabindex="-1" role="dialog" aria-labelledby="allEmployeesModalLabel" aria-hidden="true">
                                    <div class="modal-dialog modal-lg" role="document">
                                        <div class="modal-content">
                                            <div class="modal-header">
                                                <h5 class="modal-title" id="allEmployeesModalLabel">All Employees</h5>
                                                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                                    <span aria-hidden="true">&times;</span>
                                                </button>
                                            </div>
                                            <div class="modal-body">
                                                <table id="stepEmployeeTable">
                                                    <thead>
                                                        <tr>
                                                            <th>First Name</th>
                                                            <th>Last Name</th>
                                                            <th>Step Description</th>
                                                            <th>Start date</th>
                                                            <th>Current Step Employee Salary</th>
                                                            <th>Review date</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var projectBoard in Model.ProjectBoardList)
                                                        {
                                                            foreach (var employee in projectBoard.Employees)
                                                            {
                                                                foreach (var step in employee.Steps)
                                                                {
                                                                    <tr>
                                                                        <td>@employee.Person.FirstName</td>
                                                                        <td>@employee.Person.LastName</td>
                                                                        <td>@step.Description</td>
                                                                        <td>@step.StartingDate</td>
                                                                        <td>@employee.CurrentStepEmployeeSalary</td>
                                                                        <td>@step.ReviewDate</td>
                                                                    </tr>
                                                                }
                                                            }
                                                        }
                                                    </tbody>
                                                </table>

                                            </div>
                                            <div class="modal-footer">
                                                <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>


                                <div class="modal fade" id="detailedBudgetModal" tabindex="-1" role="dialog" aria-labelledby="detailedBudgetModalLabel" aria-hidden="true">
                                    <div class="modal-dialog modal-lg" role="document">
                                        <div class="modal-content">
                                            <div class="modal-header">
                                                <h5 class="modal-title" id="detailedBudgetModalLabel">Total Projects Expenses: @ViewBag.TotalProjectExpenses€</h5>
                                                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                                    <span aria-hidden="true">&times;</span>
                                                </button>
                                            </div>
                                            <div class="modal-body">
                                                <table id="detailedBudgetTable">
                                                    <thead>
                                                        <tr>
                                                            <th>Project Name</th>
                                                            <th>Manager salary</th>
                                                            <th>Employee</th>
                                                            <th>Step Budget</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var projectBoard in Model.ProjectBoardList)
                                                        {
                                                            foreach (var employee in projectBoard.Employees)
                                                            {
                                                                foreach (var step in employee.Steps)
                                                                {
                                                                    <tr>
                                                                        <td>@projectBoard.Project.Name</td>
                                                                        <td>@employee.Manager.ManagerSalary.ToString("N")</td>
                                                                        <td>@employee.CurrentStepEmployeeSalary.ToString("N")</td>
                                                                        <td>@step.StepBudget.ToString("N")</td>
                                                                    </tr>
                                                                }
                                                            }
                                                        }
                                                        <tr>
                                                            <td>Total</td>
                                                            <td>@Model.ProjectBoardList.Sum(pb => pb.Employees.Sum(e => e.Manager.ManagerSalary)).ToString("N")</td>
                                                            <td>@Model.ProjectBoardList.Sum(pb => pb.Employees.Sum(e => e.CurrentStepEmployeeSalary)).ToString("N")</td>
                                                            <td>@Model.ProjectBoardList.Sum(pb => pb.Employees.Sum(e => e.Steps.Sum(s => s.StepBudget))).ToString("N")</td>

                                                        </tr>

                                                    </tbody>
                                                </table>
                                            </div>
                                            <div class="modal-footer">
                                                <div>
                                                    <p style="text-align: left;">Grand Total: @Model.ProjectBoardList.Sum(pb => pb.Employees.Sum(e => e.Manager.ManagerSalary) + pb.Employees.Sum(e => e.CurrentStepEmployeeSalary) + pb.Employees.Sum(e => e.Steps.Sum(s => s.StepBudget))).ToString("N")</p>
                                                </div>
                                                <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="modal fade" id="InitialBudgetModal" tabindex="-1" role="dialog" aria-labelledby="initialBudgetBudgetModalLabel" aria-hidden="true">
                                    <div class="modal-dialog modal-lg" role="document">
