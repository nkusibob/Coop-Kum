@section Scripts {
    <script src="https://cdn.datatables.net/1.11.3/js/jquery.dataTables.min.js"></script>
    <script>
        $(document).ready(function () {
            var table = $('#membersTable').DataTable({
                "paging": true,
                "pageLength": 10
            });
            var table2 = $('#OnlineMembers').DataTable({
                "paging": true,
                "pageLength": 10
            });
            $(function () {
                $('#simulationForm').submit(function (event) {
                    event.preventDefault(); // Prevent the form from being submitted

                    var formData = $(this).serialize(); // Serialize the form data

                    // Submit the form data using AJAX
                    $.ajax({
                        type: 'POST',
                        url: '@Url.Action("GetSimulation")',
                        data: formData,
                        success: function (result) {
                            // Handle the response
                            console.log(result);

                            $("#simulationPeriod").text(result.sentence);

                        },
                        error: function (xhr, status, error) {
                            // Handle errors
                            console.log(xhr.responseText);
                        }
                    });
                });
            });
            $(function () {
                var allCards = $('.project-card');

                $('#searchString').on('keyup', function () {
                    var value = $(this).val().toLowerCase();

                    if (value === '') {
                        // Reset visibility of all cards
                        $('.project-card').show();

                        // Calculate the number of cards that can fit in the available space
                        var cardWidth = $('.project-card').width();
                        var containerWidth = $('.grid-container').width();
                        var numCards = Math.floor(containerWidth / cardWidth);

                        // Show only the first 'numCards' cards
                        $('.project-card').slice(0, numCards).show();

                        // Re-order the cards in the grid
                        $('.grid-container').each(function () {
                            var cards = $(this).find('.project-card');
                            cards.sort(function (a, b) {
                                return parseInt($(a).data('order')) - parseInt($(b).data('order'));
                            });
                            $(this).empty().append(cards);
                            // Simulate refresh of the page
                            location.reload();
                        });
                    } else {
                        var visibleCards = allCards.filter(function () {
                            return $(this).text().toLowerCase().indexOf(value) > -1;
                        });

                        $('.project-card').hide();
                        visibleCards.show();

                        $('.grid-container').empty();
                        visibleCards.each(function () {
                            $('.grid-container').append($(this));


                        });
                    }
                });
            });
            
            $(function() {
              // Get the height of the simulationPeriod element
              var height = $('#accordionCard #simulationPeriod').height();
              // Set the min-height and max-height of the accordion card body to the height of the simulationPeriod element
              $('#collapseThree').css({'min-height': height, 'max-height': height});
            });


            //$(function () {
            //    $('.details-btn').on('click', function (event) {
            //        event.preventDefault(); // prevent default behavior of the link
            //        var url = $(this).attr('href');
            //        $.get(url, function (data) {
            //            $('#project-details').html(data); // display the project details in the div
            //            $('#project-details-modal').modal('show'); // display the modal
            //        });
            //    });
            //});
            $(function () {
                // Add event listener to edit button
                $('.edit-btn').on('click', function (event) {
                    event.preventDefault();
                    var url = $(this).attr('href');
                    $.ajax({
                        type: 'GET',
                        url: url,
                        success: function (data) {
                            $('#project-edit-modal-body').html(data);
                            $('#project-edit-modal').modal('show');

                            // Add event listener to modal
                            $('#project-edit-modal').on('hidden.bs.modal', function () {
                                // Remove focus from any element within modal
                                $('#project-edit-modal').find(':focus').blur();
                            });
                        },
                        error: function (xhr, status, error) {
                            // Handle error
                        }
                    });
                });
            });
        

            $(function () {
                // Add event listener to add offline member button
                $('.offlineMember-add-btn').on('click', function (event) {
                    event.preventDefault(); // prevent default behavior of the link
                    var url = $(this).attr('href');
                    $.get(url, function (data) {
                        $('#offlineMember-add').html(data); // display the project details in the div
                        $('#offlineMember-add-modal').modal('show'); // display the modal
                    });
                });

                // Add event listener to create project button

            });
            $(function () {
                $('.project-create-btn').on('click', function (event) {
                    event.preventDefault(); // prevent default behavior of the link
                    var url = $(this).attr('href');
                    $.get(url, function (data) {
                        $('#project-create').html(data); // display the project details in the div
                        $('#project-create-modal').modal('show'); // display the modal
                    });
                });

            });


            $('#filterDropdown').on('change', function () {
                var filterValue = this.value;

                if (filterValue === '') {
                    table.search('').columns().search('').draw();
                } else if (filterValue === 'paid') {
                    table.column(3).search('checked').draw();
                } else if (filterValue === 'unpaid') {
                    table.column(3).search('').draw();
                    table.column(3).nodes().to$().find('input[type="checkbox"]:not(:checked)').closest('tr').remove();
                }
            });
        });
    </script>
}






