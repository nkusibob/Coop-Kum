                                                    <thead>
                                                        <tr>
                                                            <th>Review Date</th>
                                                            <th>Project</th>
                                                            <th>Step</th>
                                                            <th>Manage</th>
                                                            <th>Employee</th>
                                                            <th>Budget</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @{
                                                            decimal totalManagerSalary = 0;
                                                            decimal totalEmployeeSalary = 0;
                                                            decimal totalStepBudget = 0;
                                                        }

                                                        @foreach (var projectBoard in Model.ProjectBoardList)
                                                        {
                                                            foreach (var step in projectBoard.Steps)
                                                            {
                                                                var managerSalary = step.Employee.Manager.ManagerSalary;
                                                                var employeeSalaryPerDay = step.Employee.DailySalary;
                                                                var stepBudget = step.StepBudget;

                                                                decimal stepTotalSalary = step.NbreOfDays * employeeSalaryPerDay;

                                                                <tr class="zoom-effect">
                                                                    <td>@step.ReviewDate</td>
                                                                    <td>@projectBoard.Project.Name</td>
                                                                    <td>@step.Description</td>
                                                                    <td>@managerSalary.ToString(".##") &euro;</td>
                                                                    <td>@stepTotalSalary.ToString(".##") &euro;</td>
                                                                    <td>@stepBudget.ToString(".##") &euro;</td>
                                                                </tr>

                                                                totalManagerSalary += managerSalary;
                                                                totalEmployeeSalary += stepTotalSalary;
                                                                totalStepBudget += stepBudget;
                                                            }
                                                        }

                                                        <tr>
                                                            <td>Total</td>
                                                            <td>All</td>
                                                            <td>Details</td>
                                                            <td>@totalManagerSalary.ToString(".##") &euro;</td>
                                                            <td>@totalEmployeeSalary.ToString(".##") &euro;</td>
                                                            <td>@totalStepBudget.ToString(".##") &euro;</td>
                                                        </tr>
                                                    </tbody>
                                                </table>
