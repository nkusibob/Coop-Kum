                                                        @foreach (var projectBoard in Model.ProjectBoardList)
                                                        {
                                                            foreach (var employee in projectBoard.Employees)
                                                            {
                                                                // Get the steps associated with the current employee
                                                                var stepsForEmployee = projectBoard.Steps.Where(s => s.Employee == employee);

                                                                // Calculate the sum of CurrentEmployeeAllStepsSalary for the employee's steps
                                                                var totalSalaryForEmployee = stepsForEmployee.Sum(s => s.Employee.CurrentEmployeeAllStepsSalary);

                                                                <tr class="zoom-effect">
                                                                    <td>@Html.DisplayFor(model => employee.Person.FirstName)</td>
                                                                    <td>@Html.DisplayFor(model => employee.Person.LastName)</td>
                                                                    <td>@projectBoard.Project.Name</td>
                                                                    <td>@string.Format("{0:0.00 €; -0.00 €}", totalSalaryForEmployee) </td>
                                                                </tr>
                                                            }
                                                        }


