                    <div class="row">
                        <div class="col-sm-12 col-md-12 col-lg-3">
                            <div class="account-card">
                                <form method="post" id="simulationForm">
                                    <div class="form-group">
                                        <label for="goalToReach">Goal to Reach:</label>
