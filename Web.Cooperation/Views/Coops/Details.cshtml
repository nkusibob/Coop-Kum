            <div class="col-md-12">
                <a class="carousel-control-prev" href="#myCarousel" role="button" data-slide="prev">
                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                </a>
                <ol class="carousel-indicators carousel-container" style="background-color: #555;">
                    <li data-target="#myCarousel" data-slide-to="0" class="active"></li>
                    <li data-target="#myCarousel" data-slide-to="1"></li>
                    @for (var i = 2; i < Model.OfflineMembers.Count + 2; i++)
                    {
                        <li data-target="#myCarousel" data-slide-to="@i"></li>
                    }
                </ol>
                <a class="carousel-control-next" href="#myCarousel" role="button" data-slide="next">
                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                </a>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12 carousel-container">
                <div id="myCarousel" class="carousel slide" data-ride="carousel" data-interval="5000">
                    <div class="carousel-inner">

                        <!-- First Carousel Item - Hello Message -->
                        <div class="carousel-item active">
                            <div class="project-card text-center container">
                                <h3 class="text-wrap text-break text-responsive">Hello, @ViewBag.Title!</h3>
                                <h5 class="word-wrap:break-word;overflow-wrap: break-word;" style="width:80%;">@ViewBag.CoopPitch</h5>
                            </div>
                        </div>

                        <!-- Carousel Items for Offline Members -->
                        @foreach (var member in Model.OfflineMembers)
                        {
                            <div class="carousel-item">
                                <div class="project-card text-center container">
                                    <div class="row">
                                        <div>
                                            @if (member != null && member.Images != null && member.Images.Any())
                                            {
                                                <div class="image-gallery">
                                                    @foreach (var image in member.Images)
                                                    {
                                                        if (image != null && image.Data != null && image.Data.Length > 0)
                                                        {
                                                            <div class="image-container">
                                                                <img class="img-fluid" src="data:image/jpeg;base64,@Convert.ToBase64String(image.Data)" alt="@member.Person.LastName @member.Person.FirstName">
                                                            </div>
                                                        }
                                                    }
                                                </div>
                                            }
                                        </div>
                                        <h5 class="text-wrap text-break text-responsive">@member.Person.LastName @member.Person.FirstName</h5>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
