                } else if (filterValue === 'paid') {
                    table.column(3).search('checked').draw();
                } else if (filterValue === 'unpaid') {
                    table.column(3).search('').draw();
                    table.column(3).nodes().to$().find('input[type="checkbox"]:not(:checked)').closest('tr').remove();
                }
            });

            $('#livestockTable').on('click', '.livestock-edit-btn', function (event) {
                event.preventDefault(); // prevent default behavior of the link
                var url = '@Url.Action("UpdateDetails", "Livestock")';
                var livestockId = $(this).data('livestock-id');
                var targetModal = '#livestockEdit-modal-' + livestockId;
                var modalContent = $(targetModal).find('.modal-body');

                // Append the livestockId to the URL
                url += '?livestockId=' + livestockId;

                $.get(url, function (data) {
                    modalContent.html(data); // display the modal content retrieved from the server
                    $(targetModal).modal('show'); // display the modal
                });
            });

