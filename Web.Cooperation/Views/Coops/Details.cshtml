            function addDays(date, days) {
                var result = new Date(date);
                result.setDate(result.getDate() + days);
                return result;
            }

            function loadAvailableLivestock() {
                var idCoop = @Model.PersonList.FirstOrDefault().MyCoop.IdCoop;

                $.ajax({
                    type: 'GET',
                    url: '/Livestock/ListAvailableLivestock?idCoop=' + idCoop,
                    dataType: 'json',
                    success: function (data) {
                        if (data.length > 0) {
                            var html = '<table id="livestockTable" class="table table-responsive table-hover-effect">' +
                                '<thead>' +
                                '<tr>' +
                                '<th>livestockType</th>' +
                                '<th>Name</th>' +
                                '<th>Gender</th>' +
                                '<th>Age</th>' +
                                '<th>Last Dropped</th>' +
                                '<th>NumFemalesPaired</th>' +
                                '</tr>' +
                                '</thead>' +
                                '<tbody>';

                            var currentDate = new Date(); // Get the current date

                            for (var i = 0; i < data.length; i++) {
                                var lastDroppedDate = new Date(data[i].lastDropped); // Convert the lastDropped date to a Date object

                                var rowClass = '';
                                if (lastDroppedDate >= currentDate && lastDroppedDate <= addDays(currentDate, 14)) {
                                    rowClass = 'future-date'; // If the lastDropped date is within the range (current date to 2 weeks in the future), apply the 'future-date' class
                                } else if (lastDroppedDate > currentDate) {
                                    rowClass = 'upcoming-date'; // If the lastDropped date is in the future but beyond 2 weeks, apply the 'upcoming-date' class
                                }

                                html += '<tr class="' + rowClass + '">' +
                                    '<td>' + data[i].livestockType + '</td>' +
                                    '<td>' + data[i].name + '</td>' +
                                    '<td>' + data[i].gender + '</td>' +
                                    '<td>' + data[i].age + '</td>' +
                                    '<td>' + data[i].lastDropped + '</td>' +
                                    '<td>' + data[i].numFemalesPaired + '</td>' +
                                    '</tr>';
                            }

                            html += '</tbody>' +
                                '</table>';

                            $('#livestockModalContent').html(html);
                            $('#livestockModal').modal('show');

                            $('#livestockTable').DataTable({
                                paging: true,
                                searching: true,
                                ordering: true,
                                info: true,
                                lengthChange: true,
                                pageLength: 10,
                                language: {
                                    paginate: {
                                        first: "First",
                                        last: "Last",
                                        next: "Next",
                                        previous: "Previous"
                                    },
                                    search: "Search:",
                                    lengthMenu: "Display _MENU_ records per page",
                                    info: "Showing _START_ to _END_ of _TOTAL_ records"
                                },
                                dom: 'lBfrtip',
                                buttons: [
                                    'copy', 'csv', 'excel', 'pdf', 'print'
                                ]
                            });
                        } else {
                            $('#livestockModalContent').html('<p>You have no livestock.</p>');
                            $('#livestockModal').modal('show');
                        }
                        $('#livestockModal').on('hidden.bs.modal', function () {
                            // Refresh the page
                            location.reload();
                        });
                    },
                    error: function () {
                        $('#livestockModalContent').html('<p>An error occurred.</p>');
                        $('#livestockModal').modal('show');
                    }
                });

            }
            // Function to add days to a date


            $(function () {
                var allCards = $('.project-card');

                $('#searchString').on('keyup', function () {
                    var value = $(this).val().toLowerCase();

                    if (value === '') {
                        // Reset visibility of all cards
                        $('.project-card').show();

                        // Calculate the number of cards that can fit in the available space
                        var cardWidth = $('.project-card').width();
                        var containerWidth = $('.grid-container').width();
                        var numCards = Math.floor(containerWidth / cardWidth);

                        // Show only the first 'numCards' cards
                        $('.project-card').slice(0, numCards).show();

                        // Re-order the cards in the grid
                        $('.grid-container').each(function () {
                            var cards = $(this).find('.project-card');
                            cards.sort(function (a, b) {
                                return parseInt($(a).data('order')) - parseInt($(b).data('order'));
                            });
                            $(this).empty().append(cards);
                            // Simulate refresh of the page
                            location.reload();
                        });
                    } else {
                        var visibleCards = allCards.filter(function () {
                            return $(this).text().toLowerCase().indexOf(value) > -1;
                        });

                        $('.project-card').hide();
                        visibleCards.show();

                        $('.grid-container').empty();
                        visibleCards.each(function () {
                            $('.grid-container').append($(this));


                        });
                    }
                });
            });

