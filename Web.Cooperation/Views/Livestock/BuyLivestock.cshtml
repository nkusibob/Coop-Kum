@model Web.Cooperation.Models.ViewModel.BuyLivestockViewModel

<h2>Buy Livestock</h2>

@using (Html.BeginForm())
{
    <div class="form-group">
        <label for="Name">Name</label>
        @Html.TextBoxFor(model => model.Name, new { @class = "form-control" })
        @Html.ValidationMessageFor(model => model.Name, "", new { @class = "text-danger" })
    </div>

    <div class="form-group">
        <label for="GenderInput">Gender</label>
        @Html.TextBoxFor(model => model.GenderInput, new { @class = "form-control" })
        @Html.ValidationMessageFor(model => model.GenderInput, "", new { @class = "text-danger" })
    </div>

    <div class="form-group">
        <label for="Input">Input</label>
        @Html.TextBoxFor(model => model.Input, new { @class = "form-control" })
        @Html.ValidationMessageFor(model => model.Input, "", new { @class = "text-danger" })
    </div>

    <div class="form-group">
        <label for="Price">Price</label>
        @Html.TextBoxFor(model => model.Price, new { @class = "form-control" })
        @Html.ValidationMessageFor(model => model.Price, "", new { @class = "text-danger" })
    </div>

    <input type="hidden" name="idCoop" value="@Model.IdCoop" />

    <button type="submit" class="btn btn-primary">Buy Livestock</button>
}
