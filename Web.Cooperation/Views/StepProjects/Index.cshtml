@model IEnumerable<Model.Cooperative.StepProject>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.NbreOfDays)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.StepBuget)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Description)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ReviewDate)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.NbreOfDays)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.StepBuget)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Description)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ReviewDate)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.StepProjectId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.StepProjectId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.StepProjectId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
