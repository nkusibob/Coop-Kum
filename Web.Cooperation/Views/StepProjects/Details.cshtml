@model Model.Cooperative.StepProject

<div class="card">
    <div class="card-body">
        <h5 class="card-title">@Html.DisplayFor(model => model.Description)</h5>
        <div class="row">
            <div class="col-sm-6">
                <p class="card-text"><strong>@Html.DisplayNameFor(model => model.NbreOfDays):</strong> @Html.DisplayFor(model => model.NbreOfDays)</p>
                <p class="card-text"><strong>@Html.DisplayNameFor(model => model.StepBuget):</strong> @Html.DisplayFor(model => model.StepBuget)</p>
                <p class="card-text"><strong>@Html.DisplayNameFor(model => model.ReviewDate):</strong> @Html.DisplayFor(model => model.ReviewDate)</p>
            </div>
            <div class="col-sm-6">
                <img src="https://via.placeholder.com/150" alt="Placeholder image" class="img-fluid rounded float-end">
            </div>
        </div>
        <div class="row mt-3">
            <div class="col-sm-12">
                <p class="card-text"><strong>Full Name:</strong> @ViewBag.FullName</p>
            </div>
        </div>
        <div class="row mt-3">
            <a href="@Url.Action("Edit", "StepProjects", new { id = @Model.StepProjectId })" class="btn btn-outline-dark">Edit</a>

           
            <a href="##" onClick="history.go(-1); return false;" class="btn btn-outline-secondary">Back to List</a>
        </div>
    </div>
</div>
