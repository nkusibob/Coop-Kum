@model IEnumerable<Model.Cooperative.Coop>

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Cooperative Index</title>

    <style>
        /* Define the font style */
        body {
            font-family: 'Arial', sans-serif;
        }

        /* Set the background color */
        body {
            background-color: #f5f5f5;
        }

        /* Add some padding to the text */
        .text-center {
            padding: 20px;
        }

        /* Add a border to the join button */
        #join-button {
            border: 2px solid #333;
            border-radius: 5px;
            padding: 10px 20px;
            font-size: 18px;
            transition: all 0.3s ease;
        }

            /* Add a hover effect to the join button */
            #join-button:hover {
                background-color: #333;
                color: #fff;
            }
    </style>
</head>
<body>
    <div class="text-center">
        <h1 class="display-4">Welcome</h1>
        <p>
            <a href="https://www.ica.coop/fr">International Cooperative Alliance</a>
            <span id="typed-text"></span>
        </p>
    </div>

    <div class="text-center">
        <p style="text-align:right">
            an autonomous association of persons united voluntarily to meet their common economic, social and cultural needs and aspirations through a jointly owned and democratically-controlled enterprise
        </p>
        <label for="coop-search" class="calligraphy"> a.k.a :</label>
        <select id="coop-search" name="selectedCoopId" class="calligraphy">
            <option value="">-- Select a Cooperative --</option>
            @foreach (var coop in Model)
            {
                <option value="@coop.IdCoop">@coop.CoopName</option>
            }
        </select>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://code.jquery.com/ui/1.13.2/jquery-ui.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/typed.js/2.0.11/typed.min.js"></script>
    <script>
        $(function () {
            // Define the text to be typed
            var typedText = new Typed('#typed-text', {
                strings: ["Welcome to our Cooperative!", "Join us to achieve your goals!"],
                typeSpeed: 50,
                backSpeed: 30,
                loop: true
            });
        });

        $(function () {
            // Event handler for the change event of the select dropdown
            $('#coop-search').on('change', function (event) {
                var selectedCoopId = $(this).val();
                if (selectedCoopId) {
                    var redirectUrl = '/People/Create?selectedCoopId=' + selectedCoopId; // Pass the selectedCoopId as a query parameter
                    window.location.href = redirectUrl;
                }
            });
        });
    </script>
</body>
</html>
