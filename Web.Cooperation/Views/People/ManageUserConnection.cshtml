@model Model.Cooperative.ConnectedMember

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Person</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="ManageUserConnection" method="post">
            <input type="hidden" name="selectedCoopId" value="@ViewBag.selectedCoopId" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label for="additionalFees" class="control-label">Additional Fees</label>
                <input type="text" id="additionalFees" name="additionalFees" class="form-control" />
            </div>
            
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a href="##" onClick="history.go(-1); return false;">Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
